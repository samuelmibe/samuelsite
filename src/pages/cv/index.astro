---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const [cvEntry] = await getCollection('cv');
const { Content } = await render(cvEntry);
---

<BaseLayout title="CV" description={`CV — ${cvEntry.data.name}`}>
  <section class="wrap cv">
    <header class="cv__header">
      <h1>{cvEntry.data.name}</h1>
      <p class="muted cv__contact">{cvEntry.data.contact}</p>
    </header>
    <div class="cv__content">
      <Content />
    </div>
  </section>
</BaseLayout>

<style>
  .cv {
    padding-block: var(--space-5);
  }

  .cv__header {
    margin-bottom: var(--space-4);
  }

  .cv__contact {
    font-size: 0.9rem;
    margin: 0;
  }

  .cv__content :global(h2) {
    margin-top: var(--space-4);
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border);
  }

  .cv__content :global(h2:first-child) {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }

  .cv__content :global(p) {
    margin: 0 0 var(--space-1);
  }

  .cv__content :global(ul) {
    margin: 0 0 var(--space-3);
    padding-left: 1.2em;
  }

  .cv__content :global(ul ul) {
    margin-bottom: 0;
  }

  .cv__content :global(li) {
    margin-bottom: 0.35em;
  }
</style>
