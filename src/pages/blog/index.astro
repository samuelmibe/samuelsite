---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const isProd = import.meta.env.PROD;
const posts = (await getCollection('blog', ({ data }) => !isProd || !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Blog" description="Writing from Samuel.">
  <section class="wrap intro">
    <h1>Blog</h1>
  </section>

  <section class="wrap posts">
    {posts.length === 0 && <p class="muted">No posts yet.</p>}
    <ul class="posts__list">
      {posts.map((post) => (
        <li class="posts__item">
          <a href={`/blog/${post.id}/`}>
            <h2 class="posts__title">{post.data.title}</h2>
            <p class="muted posts__date">
              {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' })}
            </p>
            {post.data.description && <p class="posts__description">{post.data.description}</p>}
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .intro {
    padding-block: var(--space-5) var(--space-4);
  }

  .posts {
    padding-block: var(--space-4) var(--space-5);
    border-top: 1px solid var(--color-border);
  }

  .posts__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .posts__item + .posts__item {
    margin-top: var(--space-4);
  }

  .posts__item a {
    text-decoration: none;
    display: block;
  }

  .posts__title {
    margin-bottom: var(--space-1);
  }

  .posts__date {
    font-size: 0.85rem;
    margin-bottom: var(--space-1);
  }

  .posts__description {
    margin: 0;
  }
</style>
