---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => import.meta.env.DEV || !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="wrap post">
    <h1>{post.data.title}</h1>
    <p class="muted post__date">
      {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' })}
    </p>
    <div class="post__content">
      <Content />
    </div>
    <p class="post__back"><a href="/blog">&larr; Back to blog</a></p>
  </article>
</BaseLayout>

<style>
  .post {
    padding-block: var(--space-5);
  }

  .post__date {
    font-size: 0.9rem;
    margin-bottom: var(--space-4);
  }

  .post__content :global(h2) {
    margin-top: var(--space-4);
  }

  .post__content :global(p) {
    margin-bottom: var(--space-2);
  }

  .post__content :global(a) {
    text-decoration-color: var(--color-accent);
  }

  .post__back {
    margin-top: var(--space-4);
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border);
  }
</style>
